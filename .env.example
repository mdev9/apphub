# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=apphub-content
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Claude Proxy
# Local: http://localhost:9100
# Remote (via Cloudflare Tunnel): https://proxy.yourdomain.com
CLAUDE_PROXY_URL=http://localhost:9100

# Cloudflare Access service token (required for remote proxy)
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# AI features toggle
NEXT_PUBLIC_AI_ENABLED=true
